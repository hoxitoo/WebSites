# Скопировать в .env.local и заполнить

# URL веб-приложения Google Apps Script (docs/lead-setup.md).
# Не задан — заявки логируются в консоль сервера.
LEAD_WEBHOOK_URL=

# Прод-домен для OG-превью (после покупки домена)
